APP_NAME="FastAPI Template"
ENVIRONMENT="development"
DEBUG=true
API_PREFIX="/api"

# LLM (OpenRouter) — citation enrichment AND the distortion judge stages
OPENROUTER_API_KEY=""
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="google/gemini-3.5-flash"
LLM_TEMPERATURE=0.0

# Citation resolution / semantic index (the fallback resolver)
INDEX_DIR="index"
CORPUS_DIR="index/texts"
DISTORTION_BACKEND="mock"   # "mock" (offline) | "openrouter" (LLM judge)

# LangSmith tracing (optional; leave blank to disable)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="hackathon"
