APP_NAME="FastAPI Template"
ENVIRONMENT="development"
DEBUG=true
API_PREFIX="/api"

# LLM citation enrichment — provider: "openrouter" (Nemotron) or "vertex" (Gemini)
LLM_PROVIDER="openrouter"
LLM_TEMPERATURE=0.0

# OpenRouter (Nemotron)
OPENROUTER_API_KEY=""
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="nvidia/nemotron-3-nano-30b-a3b:free"

# Google Vertex AI (Gemini) — uses gcloud Application Default Credentials
GOOGLE_PROJECT=""
GOOGLE_MODEL="gemini-2.5-flash"
GOOGLE_LOCATION="us-central1"
GOOGLE_THINKING_BUDGET=0

# LangSmith tracing (optional; leave blank to disable)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="hackathon"
